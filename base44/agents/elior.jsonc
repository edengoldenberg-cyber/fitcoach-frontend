      ],
      "reason": "\u05d2\u05d9\u05e9\u05d4 \u05dc\u05de\u05ea\u05db\u05d5\u05e0\u05d9\u05dd \u05db\u05d3\u05d9 \u05dc\u05d4\u05de\u05dc\u05d9\u05e5 \u05e2\u05dc \u05d0\u05e4\u05e9\u05e8\u05d5\u05d9\u05d5\u05ea \u05d0\u05e8\u05d5\u05d7\u05d5\u05ea"
    }
  ],
  "whatsapp_greeting": "\u05e9\u05dc\u05d5\u05dd! \u05d0\u05e0\u05d9 \u05d0\u05dc\u05d9\u05d0\u05d5\u05e8 \ud83d\udc4b \u05d9\u05d5\u05e2\u05e5 \u05d4\u05ea\u05d6\u05d5\u05e0\u05d4 \u05d5\u05d4\u05e7\u05e0\u05d9\u05d5\u05ea \u05e9\u05dc\u05da, \u05d5\u05d2\u05dd \u05d4\u05de\u05d3\u05e8\u05d9\u05da \u05e9\u05dc\u05da \u05dc\u05de\u05e2\u05e8\u05db\u05ea FIT COACH PRO. \u05d1\u05d5\u05d0\u05d5 \u05e0\u05ea\u05d7\u05d9\u05dc \u05d1\u05e1\u05d9\u05d5\u05e8 \u05de\u05d3\u05e8\u05d9\u05da \u05e9\u05d9\u05e2\u05d6\u05d5\u05e8 \u05dc\u05da \u05dc\u05d4\u05e8\u05d2\u05d9\u05e9 \u05d1\u05e0\u05d5\u05d7 \u05d1\u05db\u05dc \u05d7\u05dc\u05e7 \u05e9\u05dc \u05d4\u05d0\u05e4\u05dc\u05d9\u05e7\u05e6\u05d9\u05d4. \u05de\u05d4 \u05ea\u05e8\u05e6\u05d4 \u05e9\u05e0\u05d4\u05ea\u05d7\u05d9\u05dc?",
  "telegram_greeting": "\u05e9\u05dc\u05d5\u05dd! \u05d0\u05e0\u05d9 \u05d0\u05dc\u05d9\u05d0\u05d5\u05e8 \ud83d\udc4b \u05d9\u05d5\u05e2\u05e5 \u05d4\u05ea\u05d6\u05d5\u05e0\u05d4 \u05d5\u05d4\u05e7\u05e0\u05d9\u05d5\u05ea \u05e9\u05dc\u05da, \u05d5\u05d2\u05dd \u05d4\u05de\u05d3\u05e8\u05d9\u05da \u05e9\u05dc\u05da \u05dc\u05de\u05e2\u05e8\u05db\u05ea FIT COACH PRO. \u05d1\u05d5\u05d0\u05d5 \u05e0\u05ea\u05d7\u05d9\u05dc \u05d1\u05e1\u05d9\u05d5\u05e8 \u05de\u05d3\u05e8\u05d9\u05da \u05e9\u05d9\u05e2\u05d6\u05d5\u05e8 \u05dc\u05da \u05dc\u05d4\u05e8\u05d2\u05d9\u05e9 \u05d1\u05e0\u05d5\u05d7 \u05d1\u05db\u05dc \u05d7\u05dc\u05e7 \u05e9\u05dc \u05d4\u05d0\u05e4\u05dc\u05d9\u05e7\u05e6\u05d9\u05d4. \u05de\u05d4 \u05ea\u05e8\u05e6\u05d4 \u05e9\u05e0\u05d4\u05ea\u05d7\u05d9\u05dc?",
  "name": "elior"
}
      "allowed_operations": [
        "read",
        "update"
      ],
      "reason": "\u05e7\u05e8\u05d9\u05d0\u05ea \u05e4\u05e8\u05d8\u05d9 \u05d4\u05de\u05ea\u05d0\u05de\u05df (\u05de\u05d8\u05e8\u05d5\u05ea, \u05de\u05d5\u05d3\u05d5\u05dc\u05d9\u05dd \u05d6\u05de\u05d9\u05e0\u05d9\u05dd) \u05d5\u05e2\u05d3\u05db\u05d5\u05df onboarding_status \u05dc\u05d0\u05d7\u05e8 \u05e1\u05d9\u05d5\u05dd \u05d4\u05d4\u05d3\u05e8\u05db\u05d4"
    },
    {
      "type": "entity",
      "entity_name": "NutritionLog",
      "allowed_operations": [
        "read"
      ],
      "reason": "\u05e7\u05e8\u05d9\u05d0\u05ea \u05d4\u05d9\u05e1\u05d8\u05d5\u05e8\u05d9\u05d9\u05ea \u05d0\u05db\u05d9\u05dc\u05d4 \u05e9\u05dc \u05d4\u05de\u05ea\u05d0\u05de\u05df \u05db\u05d3\u05d9 \u05dc\u05ea\u05ea \u05d4\u05de\u05dc\u05e6\u05d5\u05ea \u05ea\u05d6\u05d5\u05e0\u05ea\u05d9\u05d5\u05ea \u05de\u05d5\u05ea\u05d0\u05de\u05d5\u05ea"
    },
    {
      "type": "entity",
      "entity_name": "FoodItem",
      "allowed_operations": [
        "read"
      ],
      "reason": "\u05d2\u05d9\u05e9\u05d4 \u05dc\u05de\u05d9\u05d3\u05e2 \u05e2\u05dc \u05de\u05d5\u05e6\u05e8\u05d9 \u05de\u05d6\u05d5\u05df \u05db\u05d3\u05d9 \u05dc\u05d4\u05de\u05dc\u05d9\u05e5 \u05e2\u05dc \u05d1\u05d7\u05d9\u05e8\u05d5\u05ea \u05e7\u05e0\u05d9\u05d5\u05ea"
    },
    {
      "type": "entity",
      "entity_name": "Recipe",
      "allowed_operations": [

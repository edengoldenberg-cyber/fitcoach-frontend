{
  "name": "OnboardingStatus",
  "type": "object",
  "properties": {
    "trainee_email": {
      "type": "string"
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "current_step": {
      "type": "number",
      "default": 1
    },
    "skipped": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "trainee_email"
  ]
}
{
  "name": "DailyWorkoutItem",
  "type": "object",
  "properties": {
    "daily_workout_id": {
      "type": "string",
      "description": "FK \u05dc\u05d0\u05d9\u05de\u05d5\u05df \u05d9\u05d5\u05de\u05d9 (\u05d7\u05d5\u05d1\u05d4)"
    },
    "exercise_id": {
      "type": "string",
      "description": "FK \u05dc\u05d1\u05e0\u05e7 \u05d4\u05ea\u05e8\u05d2\u05d9\u05dc\u05d9\u05dd ExerciseLibrary (\u05d7\u05d5\u05d1\u05d4)"
    },
    "order_index": {
      "type": "number",
      "description": "\u05e1\u05d3\u05e8 \u05d4\u05ea\u05e8\u05d2\u05d9\u05dc \u05d1\u05d0\u05d9\u05de\u05d5\u05df (\u05d7\u05d5\u05d1\u05d4)"
    },
    "sets": {
      "type": "number",
      "default": 4,
      "description": "\u05de\u05e1\u05e4\u05e8 \u05e1\u05d8\u05d9\u05dd (\u05d1\u05e8\u05d9\u05e8\u05ea \u05de\u05d7\u05d3\u05dc 4)"
    },
    "reps_min": {
      "type": "number",
      "description": "\u05d7\u05d6\u05e8\u05d5\u05ea \u05de\u05d9\u05e0\u05d9\u05de\u05d5\u05dd (\u05d0\u05d5\u05e4\u05e6\u05d9\u05d5\u05e0\u05dc\u05d9)"
    },
    "reps_max": {
      "type": "number",
      "description": "\u05d7\u05d6\u05e8\u05d5\u05ea \u05de\u05e7\u05e1\u05d9\u05de\u05d5\u05dd (\u05d0\u05d5\u05e4\u05e6\u05d9\u05d5\u05e0\u05dc\u05d9)"
    },
    "notes_override": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9\u05d5\u05ea \u05dc\u05d9\u05d5\u05dd \u05d6\u05d4 (\u05d0\u05d5\u05e4\u05e6\u05d9\u05d5\u05e0\u05dc\u05d9)"
    },
    "name_snapshot": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d4\u05ea\u05e8\u05d2\u05d9\u05dc \u05d1\u05d6\u05de\u05df \u05d4\u05e4\u05e8\u05e1\u05d5\u05dd (\u05dc\u05e9\u05de\u05d9\u05e8\u05ea \u05d4\u05d9\u05e1\u05d8\u05d5\u05e8\u05d9\u05d4)"
    }
  },
  "required": [
    "daily_workout_id",
    "exercise_id",
    "order_index"
  ]
}
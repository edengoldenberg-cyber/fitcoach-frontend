      "type": "string"
    },
    "trainee_email": {
      "type": "string"
    },
    "sender_role": {
      "type": "string",
      "enum": [
        "coach",
        "trainee"
      ]
    },
    "text": {
      "type": "string"
    },
    "read_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "coach_email",
    "trainee_email",
    "sender_role",
    "text"
  ]
}